{
  "exclude": [
    ".cache/",
    "CHANGELOG.md"
  ],
  "tasks": {
    "pyright": "uv run -- deno run --permission-set=pyright --unstable-node-globals ./tools/pyright.cts --warnings",
    "update-changelog": "deno run --permission-set=update-changelog ./tools/update_changelog.ts"
  },
  "permissions": {
    "pyright": {
      "env": true,
      "ffi": true,
      "read": true,
      "run": true,
      "sys": [
        "osRelease"
      ],
      "write": true
    },
    "update-changelog": {
      "env": {
        "allow": [
          "GITHUB_TOKEN",
          "GH_TOKEN"
        ],
        "ignore": [
          "IGNORE_TEST_WIN32"
        ]
      },
      "net": [
        "api.github.com:443"
      ],
      "read": [
        ".git"
      ],
      "write": [
        "CHANGELOG.md"
      ]
    }
  },
  // Workaround for VitePress
  // https://github.com/denoland/deno/issues/20609#issuecomment-2762970307
  "nodeModulesDir": "auto",
  "imports": {
    "@octokit/rest": "npm:@octokit/rest@22.0.1",
    "@octokit/types": "npm:@octokit/types@16.0.0",
    "@types/node": "npm:@types/node@25.6.0",
    "isomorphic-git": "npm:isomorphic-git@1.37.6",
    "pyright": "npm:pyright@1.1.409"
  }
}
